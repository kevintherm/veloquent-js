{
  "name": "@veloquent/sdk",
  "version": "1.4.1",
  "description": "Lightweight, adapter-first JavaScript SDK for Veloquent",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "browser": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "bun run scripts/build.js",
    "test": "bun test ./tests",
    "test:integration": "RUN_INTEGRATION_TESTS=true bun test tests/integration.test.js",
    "test:integration:realtime": "RUN_INTEGRATION_TESTS=true bun test tests/integration-realtime.test.js",
    "dev": "bun run scripts/build.js --watch",
    "prepublishOnly": "bun test && bun run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "veloquent",
    "baas",
    "backend",
    "sdk",
    "adapter",
    "auth",
    "records",
    "laravel"
  ],
  "author": "kevintherm",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "axios": "^1.15.2",
    "esbuild": "^0.27.7",
    "laravel-echo": "^2.3.4",
    "pusher-js": "^8.5.0",
    "typescript": "^6.0.3"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevintherm/veloquent-js.git"
  },
  "bugs": {
    "url": "https://github.com/kevintherm/veloquent-js/issues"
  },
  "homepage": "https://github.com/kevintherm/veloquent-js#readme"
}
